# Runtime mode for the API. Optional in local dev; use production in deployed environments.
NODE_ENV=development

# HTTP port for the NestJS server. Optional; defaults to 3333 locally.
PORT=3333

# REQUIRED. PostgreSQL connection string in the format:
# postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
# The credentials below are weak and for local development only. Never use
# postgres:postgres in production. Use strong unique credentials and store them
# in a secrets manager or CI/CD environment store.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/directcash?schema=public

# REQUIRED. JWT signing secret. The value below is unsafe for production and
# MUST be replaced. Generate a strong secret with:
# openssl rand -hex 32
# or
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Store it in a secrets manager or secure environment-variable store.
JWT_SECRET=super-secret-change-me

# Optional. Token lifetime accepted by jsonwebtoken/ms, e.g. 1d, 12h, 60m.
JWT_EXPIRES_IN=1d

# REQUIRED. Dedicated refresh-token secret. Do not reuse weak values in production.
JWT_REFRESH_SECRET=super-refresh-secret-change-me

# Optional. Refresh token lifetime accepted by jsonwebtoken/ms, e.g. 7d, 30d.
JWT_REFRESH_EXPIRES_IN=7d

# REQUIRED. Bcrypt hash used to normalize login timing when the user does not exist.
FAKE_PASSWORD_HASH=$2b$10$C6UzMDM.H6dfI/f/IKcEe.O8U9U2D2Q0JqA2nU5v98d.6QG3Vq9KG

# Redis connection used by BullMQ and the campaigns worker.
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=

# Optional. Keep false by default and prefer disabled in production.
# If enabled outside production, set strong unique credentials below and avoid
# exposing docs publicly without additional controls.
SWAGGER_ENABLED=false

# Required only when SWAGGER_ENABLED=true. Leave blank by default and configure
# explicitly per environment with strong credentials.
SWAGGER_USER=

# Required only when SWAGGER_ENABLED=true. Leave blank by default and configure
# explicitly per environment with strong credentials.
SWAGGER_PASSWORD=
