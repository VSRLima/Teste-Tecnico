FROM node:22-alpine AS base
WORKDIR /app

FROM base AS deps
COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/api/prisma apps/api/prisma
COPY apps/web/package.json apps/web/package.json
COPY packages/config/package.json packages/config/package.json
RUN npm ci

FROM deps AS builder
COPY . .
RUN npm exec --workspace @directcash/api prisma generate
RUN npm run build --workspace @directcash/api

FROM base AS runner
ENV NODE_ENV=production
ENV PORT=3333
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/api/node_modules ./apps/api/node_modules
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/apps/api/package.json ./apps/api/package.json
COPY --from=builder /app/apps/api/tsconfig.json ./apps/api/tsconfig.json
COPY --from=builder /app/apps/api/tsconfig.build.json ./apps/api/tsconfig.build.json
COPY --from=builder /app/apps/api/dist ./apps/api/dist
COPY --from=builder /app/apps/api/prisma ./apps/api/prisma
RUN cd /app/apps/api && node -e "require.resolve('@prisma/client')"
EXPOSE 3333
CMD ["node", "apps/api/dist/src/main.js"]
